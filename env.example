# ============================================
# Voz Bridge - Configuration
# ============================================
# Copy this file to .env and adjust values
# cp env.example .env

# === Bridge Server ===
VOZ_BRIDGE_HOST=0.0.0.0          # Bind address (0.0.0.0 para acceso LAN)
VOZ_BRIDGE_PORT=8089              # Puerto del bridge
VOZ_BRIDGE_TOKEN=                 # Bearer token (vacio = sin auth, modo dev)
VOZ_BRIDGE_LOG_LEVEL=info         # debug | info | warning | error

# === CoPaw Upstream ===
VOZ_COPAW_HOST=127.0.0.1          # Host de CoPaw
VOZ_COPAW_PORT=8088               # Puerto de CoPaw
VOZ_COPAW_TIMEOUT=120             # Timeout en segundos para requests

# === Avanzado ===
VOZ_COPAW_BASE_URL=               # Override completo (ej: http://copaw:8088)
VOZ_DEFAULT_SESSION_PREFIX=voz-   # Prefijo para session_ids auto-generados
